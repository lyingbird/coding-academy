{
  "name": "@academy/sidecar-shell",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "academy-sidecar-shell": "./dist/index.js"
  },
  "scripts": {
    "start": "tsx src/index.ts start",
    "snapshot": "tsx src/index.ts snapshot",
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@academy/runtime": "workspace:*",
    "@academy/shared": "workspace:*"
  }
}
