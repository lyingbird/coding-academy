    "demo": "tsx src/index.ts demo",
    "status": "tsx src/index.ts status",
    "panel": "tsx src/index.ts panel",
    "watch": "tsx src/index.ts watch",
    "sidecar": "tsx src/index.ts sidecar",
    "doctor": "tsx src/index.ts doctor",
    "strategy": "tsx src/index.ts strategy",
    "burst": "tsx src/index.ts burst",
    "check-in": "tsx src/index.ts check-in",
    "ingest": "tsx src/index.ts ingest",
    "relay": "tsx src/index.ts relay",
    "relay-file": "tsx src/index.ts relay-file",
    "adapters": "tsx src/index.ts adapters",
    "adapter": "tsx src/index.ts adapter",
    "scaffold": "tsx src/index.ts scaffold",
    "bridge:init": "tsx src/index.ts bridge:init",
    "wrap": "tsx src/index.ts wrap",
    "wrap-provider": "tsx src/index.ts wrap-provider"
